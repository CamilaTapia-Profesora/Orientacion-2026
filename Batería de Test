  const curso=document.getElementById(`${tid}_curso`).value.trim()||'—';
  const fecha=document.getElementById(`${tid}_fecha`).value||new Date().toLocaleDateString('es-CL');
  const code=genCode(name);
  document.getElementById(`${tid}r_meta`).textContent=`${name} · ${curso} · ${fecha}`;
  document.getElementById(`${tid}_vcode`).textContent=code;

  if(tid==='s1') buildS1Result(name,curso,code);
