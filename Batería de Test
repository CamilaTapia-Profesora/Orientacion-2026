// ══════════════════════════════════════════
//  GENERATE VERIFY CODE
// ══════════════════════════════════════════
function genCode(name){
  const pfx=(name||'XXX').substring(0,3).toUpperCase().replace(/[^A-ZÁÉÍÓÚÑ]/g,'X');
  const rand=Math.floor(Math.random()*8999+1000);
  return `${pfx}-${new Date().getDate().toString().padStart(2,'0')}-${rand}`;
}

