function buildAll(){
  buildS1(); buildS2(); buildS3(); buildS4(); buildS5(); buildS6(); buildS7(); buildS8();
  const today = new Date().toISOString().split('T')[0];
  ['s1_fecha','s2_fecha','s3_fecha','s4_fecha','s5_fecha','s6_fecha','s7_fecha','s8_fecha'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value=today;
  });
}

function buildS1(){
  const c=document.getElementById('s1_items'); let h=''; let n=1;
  S1.groups.forEach(g=>{
    h+=`<div class="grp-head"><span class="grp-badge" style="background:${g.color};color:${g.tc};border:1px solid ${g.tc}44">${g.badge}</span><span class="grp-title"></span></div>`;
    g.items.forEach(q=>{
      h+=`<div class="item" id="s1r_${n}" data-bc="${g.tc}">
        <span class="item-n">${n}</span>
        <div class="item-body">
          <div class="item-q">${q}</div>
          <input class="item-input" type="text" placeholder="Nombre del/la compañero/a" oninput="prog('s1',20)" data-s1="${n}">
        </div></div>`; n++;
    });
  });
  h+=`<div style="margin-top:20px;"><div class="grp-head"><span class="grp-badge" style="background:rgba(244,114,27,.15);color:var(--orange);border:1px solid rgba(244,114,27,.35)">Reflexión abierta</span></div>
    <div class="fg full" style="margin-top:10px;"><label>${S1.openQ}</label><textarea class="item-input" id="s1_open" placeholder="Escribe tu respuesta..." style="min-height:75px;resize:vertical;" oninput="prog('s1',20)"></textarea></div></div>`;
  c.innerHTML=h;
}

function buildS2(){
  const c=document.getElementById('s2_items'); let h=''; let n=1;
  S2_DIMS.forEach(dim=>{
    h+=`<div class="dim-head"><div class="dim-icon" style="background:${dim.color};border:1px solid ${dim.bc}">${dim.icon}</div><div><div class="dim-title">${dim.title}</div><div class="dim-sub">${dim.sub}</div></div></div>`;
    dim.skills.forEach((sk,si)=>{
      const key=`${dim.id}_${si}`;
      h+=`<div class="skill-row" id="s2row_${key}">
        <div class="skill-q">${n}. ${sk}</div>
        <div class="radio-grp">
          ${[['c','✅ Consolidada','var(--green)'],['p','🔄 En progreso','var(--yellow)'],['b','🌱 En bruto','var(--orange)']].map(([lv,txt,col])=>`
            <input type="radio" class="ro" id="${key}_${lv}" name="${key}" data-lv="${lv}" onchange="s2Radio('${key}','${lv}','${col}');prog('s2',21)">
            <label for="${key}_${lv}" class="rl" style="--rc:${col}">${txt}</label>
          `).join('')}
        </div></div>`; n++;
    });
  });
  c.innerHTML=h;
  // Style checked radios per color
  document.querySelectorAll('#s2_items .ro').forEach(r=>{
    r.addEventListener('change',function(){
      const name=this.name;
      document.querySelectorAll(`[name="${name}"]`).forEach(o=>{
        const lbl=document.querySelector(`label[for="${o.id}"]`);
        if(o.checked){ const col=o.closest('.skill-row').querySelector(`label[for="${o.id}"]`).style.getPropertyValue('--rc')||'var(--orange)'; lbl.style.background='rgba(255,255,255,.08)'; lbl.style.borderColor=col; lbl.style.color=col; }
        else{ lbl.style.background=''; lbl.style.borderColor=''; lbl.style.color=''; }
      });
    });
  });
}

