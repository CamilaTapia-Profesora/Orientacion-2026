<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Orientación 2026 – Liceo Bernardo O'Higgins</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
:root {
  --navy: #0c1a2e;
  --orange: #f4721b;
  --orange-light: #ff9a4d;
  --green: #2ecc71;
  --green-dark: #1a9e52;
  --purple: #8b5cf6;
  --purple-light: #a78bfa;
  --yellow: #f5c518;
  --yellow-dark: #d4a017;
  --red: #e63946;
  --teal: #1abc9c;
  --cream: #f0ece3;
  --slate: #7a8299;
  --white: #ffffff;
  --card-bg: rgba(255,255,255,0.05);
  --card-border: rgba(255,255,255,0.1);
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:"DM Sans",sans-serif;background:var(--navy);color:var(--cream);min-height:100vh;overflow-x:hidden;}
body::before{content:"";position:fixed;inset:0;background:radial-gradient(ellipse at 15% 0%,rgba(244,114,27,.08) 0%,transparent 50%),radial-gradient(ellipse at 85% 100%,rgba(139,92,246,.1) 0%,transparent 50%);pointer-events:none;z-index:0;}

/* APP HEADER */
.app-header{position:sticky;top:0;z-index:1000;background:rgba(12,26,46,0.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--card-border);padding:10px 20px;display:flex;justify-content:space-between;align-items:center;}
.header-left{display:flex;align-items:center;gap:12px;}
.logo-img{height:42px;width:auto;}
.header-title{font-family:"Syne",sans-serif;font-size:16px;font-weight:700;color:var(--white);line-height:1.2;}
.header-sub{font-size:10px;color:var(--slate);letter-spacing:.08em;}
.avatar-img{height:42px;width:42px;border-radius:50%;border:2.5px solid var(--orange);object-fit:cover;}

/* SCREENS */
.screen{display:none;position:relative;z-index:1;animation:fadeUp .35s ease;}
.screen.active{display:block;}
.container{max-width:780px;margin:0 auto;padding:28px 18px 70px;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* HERO */
.hero-title{font-family:"Syne",sans-serif;font-size:clamp(22px,6vw,36px);font-weight:800;line-height:1.1;color:var(--white);margin-bottom:8px;}
.hero-title em{color:var(--orange);font-style:normal;}
.hero-sub{font-size:13px;color:var(--slate);margin-bottom:24px;}

/* MENU CARDS */
.menu-grid{display:grid;grid-template-columns:1fr;gap:12px;}
.menu-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:14px;padding:18px 20px;cursor:pointer;display:flex;align-items:center;gap:16px;transition:all .22s;}
.menu-card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.35);}
.menu-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.menu-card-body{flex:1;}
.menu-card-title{font-family:"Syne",sans-serif;font-size:15px;font-weight:700;color:var(--white);margin-bottom:3px;}
.menu-card-desc{font-size:12px;color:var(--slate);line-height:1.45;}
.menu-arrow{font-size:18px;color:var(--slate);}
.menu-done{font-family:"Syne",sans-serif;font-size:9px;font-weight:700;padding:3px 8px;border-radius:20px;background:rgba(46,204,113,.2);color:var(--green);border:1px solid rgba(46,204,113,.35);display:none;}
.menu-done.show{display:inline-block;}

.tip-box{background:rgba(244,114,27,.07);border:1px solid rgba(244,114,27,.2);border-radius:10px;padding:13px 16px;margin-top:18px;font-size:12px;color:var(--cream);line-height:1.6;}
.tip-box strong{color:var(--orange);}

/* BACK BAR */
.back-bar{display:inline-flex;align-items:center;gap:8px;margin-bottom:20px;cursor:pointer;color:var(--slate);font-size:13px;font-weight:600;transition:color .2s;padding:8px 0;}
.back-bar:hover{color:var(--orange);}

/* SECTION HEADER */
.s-badge{font-family:"Syne",sans-serif;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:8px;}
.s-title{font-family:"Syne",sans-serif;font-size:clamp(20px,5vw,30px);font-weight:800;color:var(--white);margin-bottom:6px;}
.s-title em{font-style:normal;}
.s-desc{font-size:13px;color:var(--slate);line-height:1.55;margin-bottom:22px;}

/* STUDENT CARD */
.student-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:12px;padding:18px;margin-bottom:22px;display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.fg{display:flex;flex-direction:column;gap:5px;}
.fg.full{grid-column:1/-1;}
.fg label{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--slate);}
.fg input,.fg textarea{background:rgba(0,0,0,.25);border:1px solid var(--card-border);border-radius:8px;padding:9px 13px;color:var(--white);font-family:"DM Sans",sans-serif;font-size:13px;outline:none;transition:border-color .2s;width:100%;}
.fg textarea{min-height:75px;resize:vertical;}
.fg input:focus,.fg textarea:focus{border-color:var(--orange);}

/* PROGRESS */
.prog-wrap{position:sticky;top:62px;z-index:10;padding:10px 0 6px;background:var(--navy);}
.prog-top{display:flex;justify-content:space-between;font-size:11px;color:var(--slate);margin-bottom:5px;}
.prog-bg{height:4px;background:rgba(255,255,255,.08);border-radius:99px;overflow:hidden;}
.prog-fill{height:100%;border-radius:99px;transition:width .35s ease;width:0%;}

/* INSTR BOX */
.instr-box{border-radius:10px;padding:13px 16px;margin-bottom:18px;font-size:12.5px;line-height:1.65;}

/* GROUP HEADERS */
.grp-head{display:flex;align-items:center;gap:10px;margin:20px 0 10px;padding-bottom:8px;border-bottom:1px solid var(--card-border);}
.grp-badge{font-family:"Syne",sans-serif;font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:3px 9px;border-radius:20px;flex-shrink:0;}
.grp-title{font-family:"Syne",sans-serif;font-size:13px;font-weight:700;color:var(--white);}

/* ITEM ROW */
.item{background:var(--card-bg);border:1px solid var(--card-border);border-radius:10px;padding:14px 16px;margin-bottom:8px;display:flex;align-items:flex-start;gap:12px;transition:border-color .2s;}
.item-n{font-family:"Syne",sans-serif;font-size:11px;font-weight:700;color:var(--slate);min-width:20px;padding-top:2px;}
.item-body{flex:1;}
.item-q{font-size:13px;color:var(--cream);line-height:1.45;margin-bottom:9px;}
.item-input{background:rgba(0,0,0,.25);border:1px solid var(--card-border);border-radius:7px;padding:8px 12px;color:var(--white);font-family:"DM Sans",sans-serif;font-size:13px;outline:none;transition:border-color .2s;width:100%;}
.item-input:focus{border-color:var(--orange);}

/* SKILL ROWS */
.skill-row{background:var(--card-bg);border:1px solid var(--card-border);border-radius:10px;padding:14px 16px;margin-bottom:8px;transition:border-color .2s;}
.skill-q{font-size:13px;color:var(--cream);line-height:1.45;margin-bottom:10px;font-weight:500;}

/* RADIOS */
.radio-grp{display:flex;gap:7px;flex-wrap:wrap;}
.ro{display:none;}
.rl{padding:7px 13px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;border:1.5px solid var(--card-border);transition:all .18s;user-select:none;color:var(--slate);white-space:nowrap;}

/* VOC CARDS */
.voc-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.voc-card{background:var(--card-bg);border:1.5px solid var(--card-border);border-radius:10px;padding:13px;cursor:pointer;transition:all .18s;}
.voc-card:hover{border-color:rgba(244,114,27,.4);}
.voc-card.selected{border-color:var(--orange);background:rgba(244,114,27,.1);}
.voc-label{font-family:"Syne",sans-serif;font-size:12px;font-weight:700;color:var(--white);margin-bottom:3px;}
.voc-desc{font-size:11px;color:var(--slate);line-height:1.35;}

/* LIKERT SCALE */
.likert{display:flex;gap:6px;flex-wrap:wrap;}
.lk-opt{display:none;}
.lk-lbl{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:"Syne",sans-serif;font-size:13px;font-weight:700;cursor:pointer;border:1.5px solid var(--card-border);transition:all .18s;color:var(--slate);}
.lk-lbl:hover{border-color:var(--orange);color:var(--orange);}
.lk-opt:checked+.lk-lbl{color:var(--navy);font-weight:800;}
.likert-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--slate);margin-top:5px;}

/* SUBMIT */
.submit-btn{display:flex;justify-content:center;align-items:center;gap:8px;width:100%;padding:16px;border:none;border-radius:12px;font-family:"Syne",sans-serif;font-size:15px;font-weight:700;cursor:pointer;margin-top:26px;transition:all .2s;}
.submit-btn:hover{transform:translateY(-1px);}

/* RESULTS */
.result-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:12px;padding:22px;margin-bottom:14px;}
.result-title{font-family:"Syne",sans-serif;font-size:20px;font-weight:800;color:var(--white);margin-bottom:3px;}
.result-meta{color:var(--slate);font-size:12px;margin-bottom:18px;}
.ans-block{margin-bottom:11px;padding-bottom:11px;border-bottom:1px solid var(--card-border);}
.ans-block:last-child{border-bottom:none;}
.ans-q{font-size:11px;color:var(--slate);margin-bottom:3px;line-height:1.4;}
.ans-v{font-size:13px;font-weight:600;}

/* HORIZONTAL BARS */
.bar-group{margin-bottom:14px;}
.bar-label{display:flex;justify-content:space-between;font-size:12px;font-weight:600;color:var(--cream);margin-bottom:6px;}
.bar-track{width:100%;height:12px;background:rgba(0,0,0,.3);border-radius:6px;overflow:hidden;}
.bar-fill{height:100%;border-radius:6px;width:0%;transition:width 1s cubic-bezier(.34,1.56,.64,1);}

/* VERIFY CODE */
.verify-box{background:rgba(0,0,0,.2);border:1px dashed rgba(255,255,255,.15);border-radius:10px;padding:14px;margin-bottom:14px;text-align:center;}
.verify-code{font-family:monospace;font-size:20px;font-weight:700;letter-spacing:.2em;color:var(--yellow);margin:8px 0;}
.verify-label{font-size:11px;color:var(--slate);}

/* COPY BOX */
.copy-box{background:rgba(0,0,0,.2);border:1px solid var(--card-border);border-radius:10px;padding:14px;margin-bottom:14px;}
.copy-box code{display:block;background:rgba(0,0,0,.3);padding:10px 12px;border-radius:7px;color:var(--yellow);font-family:monospace;font-size:11px;margin:8px 0;word-break:break-all;line-height:1.5;}
.copy-label{font-size:11px;color:var(--slate);margin-bottom:6px;}

/* ACTION BUTTONS */
.action-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;}
.btn-outline{flex:1;min-width:120px;background:transparent;border:1px solid var(--card-border);color:var(--cream);padding:12px;border-radius:9px;font-family:"Syne",sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;display:flex;justify-content:center;align-items:center;gap:7px;}
.btn-outline:hover{border-color:var(--orange);color:var(--orange);}
.btn-copy{border-color:rgba(46,204,113,.4);color:var(--green);}
.btn-copy:hover{background:rgba(46,204,113,.1);border-color:var(--green);color:var(--green);}
.btn-pdf{flex:1;min-width:120px;background:var(--orange);border:none;color:var(--white);padding:12px;border-radius:9px;font-family:"Syne",sans-serif;font-size:13px;font-weight:700;cursor:pointer;display:flex;justify-content:center;align-items:center;gap:7px;transition:all .2s;}
.btn-pdf:hover{background:var(--orange-light);}
.copy-feedback{color:var(--green);font-size:12px;text-align:center;margin-top:8px;display:none;}

/* PROFILE TAGS */
.tags-wrap{display:flex;flex-wrap:wrap;gap:7px;margin-top:10px;}
.tag{padding:4px 11px;border-radius:20px;font-size:11px;font-weight:600;}

/* DIM HEADER */
.dim-head{display:flex;align-items:center;gap:12px;margin:22px 0 10px;}
.dim-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.dim-title{font-family:"Syne",sans-serif;font-size:14px;font-weight:700;color:var(--white);}
.dim-sub{font-size:11px;color:var(--slate);margin-top:2px;}

@media(max-width:560px){
  .student-card{grid-template-columns:1fr;}
  .voc-grid{grid-template-columns:1fr;}
  .action-row{flex-direction:column;}
  .btn-outline,.btn-pdf{min-width:unset;}
  .likert{gap:4px;}
  .lk-lbl{width:32px;height:32px;font-size:12px;}
}
</style>
</head>
<body>

<!-- APP HEADER -->
<header class="app-header">
  <div class="header-left">
    <img src="data:image/png;base64," alt="Logo LBO" class="logo-img">
    <div>
      <div class="header-title">Orientación 2026</div>
      <div class="header-sub">Liceo Bernardo O'Higgins · Iquique</div>
    </div>
  </div>
  <div class="header-right">
    <img src="data:image/png;base64," alt="Docente" class="avatar-img">
  </div>
</header>

<!-- ══ MENÚ ══ -->
<div id="s0" class="screen active">
<div class="container">
  <h1 class="hero-title" style="margin-top:8px;">Batería de<br><em>Orientación</em></h1>
  <p class="hero-sub">Completa los tests en orden · Departamento de Orientación · 2° Medio</p>

  <div class="menu-grid">
    <div class="menu-card" onclick="go('s1')" id="card_s1" style="border-color:rgba(244,114,27,.25);">
      <div class="menu-icon" style="background:rgba(244,114,27,.15);">🤝</div>
      <div class="menu-card-body">
        <div class="menu-card-title">1 · Test Sociométrico <span class="menu-done" id="done_s1">✓ Listo</span></div>
        <div class="menu-card-desc">¿Cómo percibes a tus compañeros/as? Nominaciones por conducta y actitud.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s2')" id="card_s2" style="border-color:rgba(46,204,113,.2);">
      <div class="menu-icon" style="background:rgba(46,204,113,.15);">🌱</div>
      <div class="menu-card-body">
        <div class="menu-card-title">2 · Habilidades Personales <span class="menu-done" id="done_s2">✓ Listo</span></div>
        <div class="menu-card-desc">Autoevaluación de competencias SEL, cognitivas y comunicativas.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s3')" id="card_s3" style="border-color:rgba(139,92,246,.2);">
      <div class="menu-icon" style="background:rgba(139,92,246,.15);">🧠</div>
      <div class="menu-card-body">
        <div class="menu-card-title">3 · Inteligencias Múltiples <span class="menu-done" id="done_s3">✓ Listo</span></div>
        <div class="menu-card-desc">¿Dónde está tu verdadera inteligencia? Basado en Gardner.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s4')" id="card_s4" style="border-color:rgba(245,197,24,.2);">
      <div class="menu-icon" style="background:rgba(245,197,24,.15);">📚</div>
      <div class="menu-card-body">
        <div class="menu-card-title">4 · Tipo de Estudiante <span class="menu-done" id="done_s4">✓ Listo</span></div>
        <div class="menu-card-desc">¿Cómo aprendes y trabajas mejor? Estilo individual vs. grupal.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s5')" id="card_s5" style="border-color:rgba(26,188,156,.2);">
      <div class="menu-icon" style="background:rgba(26,188,156,.15);">👁️</div>
      <div class="menu-card-body">
        <div class="menu-card-title">5 · Recepción de la Información <span class="menu-done" id="done_s5">✓ Listo</span></div>
        <div class="menu-card-desc">¿Aprendes más viendo, escuchando o haciendo? Canal VAK.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s6')" id="card_s6" style="border-color:rgba(230,57,70,.2);">
      <div class="menu-icon" style="background:rgba(230,57,70,.15);">💎</div>
      <div class="menu-card-body">
        <div class="menu-card-title">6 · Tipo de Ser Social <span class="menu-done" id="done_s6">✓ Listo</span></div>
        <div class="menu-card-desc">¿Qué valoras en la vida? Perfil de orientación social y vocacional.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s7')" id="card_s7" style="border-color:rgba(26,188,156,.2);">
      <div class="menu-icon" style="background:rgba(26,188,156,.15);">💪</div>
      <div class="menu-card-body">
        <div class="menu-card-title">7 · Test de Autoestima <span class="menu-done" id="done_s7">✓ Listo</span></div>
        <div class="menu-card-desc">¿Cómo te valoras a ti mismo/a? 20 afirmaciones con escala De acuerdo / Desacuerdo / No sé.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>

    <div class="menu-card" onclick="go('s8')" id="card_s8" style="border-color:rgba(245,197,24,.2);">
      <div class="menu-icon" style="background:rgba(245,197,24,.15);">🔭</div>
      <div class="menu-card-body">
        <div class="menu-card-title">8 · Orientación Vocacional <span class="menu-done" id="done_s8">✓ Listo</span></div>
        <div class="menu-card-desc">¿Qué camino quieres seguir? Explora intereses, proyección de futuro y estilo de vida.</div>
      </div>
      <span class="menu-arrow">›</span>
    </div>
  </div>

  <div class="tip-box">
    <strong>¿Cómo funciona?</strong> Completa los 8 tests en orden. Cada uno genera un PDF con tus resultados. Al terminar, muéstraselo a tu profesora. Tus respuestas son confidenciales.
  </div>
</div>
</div>

<!-- ══ TEST 1: SOCIOMÉTRICO ══ -->
<div id="s1" class="screen">
<div class="container">
  <div class="back-bar" onclick="go('s0')">← Menú principal</div>
  <div class="s-badge" style="color:var(--orange)">Test 1 de 8</div>
  <h1 class="s-title" style="color:var(--white);">Test <em style="color:var(--orange)">Sociométrico</em></h1>
  <p class="s-desc">Escribe el nombre completo de un/a compañero/a que destaque en cada situación. No hay respuestas correctas.</p>

  <div class="student-card">
    <div class="fg full"><label>Tu nombre completo</label><input type="text" id="s1_name" placeholder="Nombre y apellidos"></div>
    <div class="fg"><label>Curso</label><input type="text" id="s1_curso" placeholder="2°A…"></div>
    <div class="fg"><label>Fecha</label><input type="date" id="s1_fecha"></div>
  </div>

  <div class="prog-wrap">
    <div class="prog-top"><span id="s1_ptxt">Completa todas las nominaciones</span><span id="s1_pcnt">0 / 20</span></div>
    <div class="prog-bg"><div class="prog-fill" id="s1_pfill" style="background:linear-gradient(90deg,var(--orange),var(--yellow));"></div></div>
  </div>

  <div id="s1_items"></div>
  <button class="submit-btn" style="background:var(--orange);color:var(--navy);" onclick="showResult('s1')">Ver mis respuestas →</button>
</div>
</div>

<div id="s1r" class="screen">
<div class="container">
  <div class="back-bar" onclick="go('s1')">← Volver al test</div>
  <div class="result-card" id="s1_pdf_content">
    <div class="result-title">Test Sociométrico</div>
    <div class="result-meta" id="s1r_meta"></div>
    <div id="s1r_answers"></div>
  </div>
  <div class="verify-box">
    <div class="verify-label">Código de verificación (muéstraselo a tu docente)</div>
    <div class="verify-code" id="s1_vcode"></div>
  </div>
  <div class="copy-box">
    <div class="copy-label">📋 Datos para tabulación docente</div>
    <code id="s1_forms_code"></code>
    <button class="btn-outline btn-copy" style="width:100%;margin-top:6px;" onclick="copyData('s1')">Copiar datos</button>
    <div class="copy-feedback" id="s1_copy_fb">¡Copiado!</div>
  </div>
  <div class="action-row">
    <button class="btn-outline" onclick="go('s0')">← Menú</button>
    <button class="btn-pdf" onclick="exportPDF('s1_pdf_content','Sociometrico')">⬇ Descargar PDF</button>
    <button class="btn-outline" onclick="go('s2')" style="border-color:var(--green);color:var(--green);">Siguiente →</button>
  </div>
</div>
</div>

<!-- ══ TEST 2: HABILIDADES ══ -->
<div id="s2" class="screen">
<div class="container">
  <div class="back-bar" onclick="go('s0')">← Menú principal</div>
