// TEST 8: VOCACIONAL
const S8_ITEMS = [
  {type:'radio',q:'¿Cómo prefieres aprender algo nuevo?',opts:['Leyendo o investigando por mi cuenta','Escuchando, debatiendo o conversando','Haciendo, practicando o experimentando','Creando, diseñando o construyendo']},
  {type:'radio',q:'¿Qué tipo de actividades disfrutas más en el colegio?',opts:['Analizar datos, resolver problemas o hacer cálculos','Ayudar, cuidar o escuchar a otras personas','Trabajar con tecnología, herramientas o materiales','Expresarme: escribir, dibujar, actuar o diseñar']},
  {type:'radio',q:'¿Cómo te describes mejor al trabajar en grupo?',opts:['El/la que analiza y aporta ideas','El/la que organiza y lidera','El/la que ejecuta y hace cosas concretas','El/la que media, escucha y apoya']},
  {type:'radio',q:'¿Qué te motiva más al pensar en tu futuro?',opts:['Tener un trabajo estable y con buena remuneración','Hacer algo que me apasione, aunque sea difícil','Ayudar a la comunidad o a personas que lo necesitan','Crear o innovar algo nuevo en mi área']},
  {type:'radio',q:'¿Te ves más en una carrera técnica o universitaria?',opts:['Técnica: quiero especializarme y trabajar pronto','Universitaria: quiero estudiar en profundidad un área','Todavía no lo sé con claridad','Me da igual, lo que importa es lo que hago']},
  {type:'voc',q:'¿Cuál de estas áreas te llama más la atención?',opts:[
    {label:'Salud y Bienestar',desc:'Enfermería, kinesiología, psicología, nutrición'},
    {label:'Tecnología e Ingeniería',desc:'Programación, electrónica, mecánica, informática'},
    {label:'Artes y Comunicación',desc:'Diseño, periodismo, música, publicidad, audiovisual'},
    {label:'Ciencias Exactas',desc:'Física, química, biología, matemáticas'},
    {label:'Ciencias Sociales y Humanidades',desc:'Historia, derecho, educación, trabajo social'},
    {label:'Administración y Negocios',desc:'Contabilidad, logística, comercio, gestión'},
  ]},
  {type:'text',q:'¿Hay alguna persona (familiar, famoso/a, personaje) que admires por su trabajo? ¿Qué hace?'},
  {type:'text',q:'¿Qué actividad podrías hacer por horas sin aburrirte?'},
  {type:'text',q:'¿Qué te preocupa o genera más dudas al pensar en qué estudiar o trabajar después del liceo?'},
  {type:'text',q:'¿Hay algo más que quieras compartir sobre lo que sueñas o proyectas para tu futuro?'},
];
const S8_ANSWERS = {};

function buildS7(){
  const c=document.getElementById('s7_items'); let h='';
  S7_ITEMS.forEach(item=>{
    h+=`<div class="skill-row">
      <div class="skill-q">${item.n}. ${item.text} ${item.inv?'<span style="font-size:10px;color:var(--slate)">(ítem inverso)</span>':''}</div>
      <div class="radio-grp">
        ${[['A','De acuerdo','var(--green)'],['D','Desacuerdo','var(--orange)'],['N','No sé','var(--slate)']].map(([val,txt,col])=>`
          <input type="radio" class="ro" id="s7_${item.n}_${val}" name="s7_${item.n}" value="${val}" onchange="prog('s7',20)">
          <label for="s7_${item.n}_${val}" class="rl" style="--rc:${col}">${txt}</label>
        `).join('')}
      </div></div>`;
  });
  c.innerHTML=h;
  document.querySelectorAll('#s7_items .ro').forEach(r=>{
    r.addEventListener('change',function(){
      const name=this.name;
      document.querySelectorAll(`[name="${name}"]`).forEach(o=>{
        const lbl=document.querySelector(`label[for="${o.id}"]`);
        const col=o.value==='A'?'var(--green)':o.value==='D'?'var(--orange)':'var(--slate)';
        if(o.checked){lbl.style.background='rgba(255,255,255,.08)';lbl.style.borderColor=col;lbl.style.color=col;}
        else{lbl.style.background='';lbl.style.borderColor='';lbl.style.color='';}
      });
    });
  });
}

function buildS8(){
  const c=document.getElementById('s8_items'); let h='';
  S8_ITEMS.forEach((item,i)=>{
    if(item.type==='radio'){
      h+=`<div class="skill-row">
        <div class="skill-q">${i+1}. ${item.q}</div>
        <div class="radio-grp" style="flex-direction:column;gap:6px;">
          ${item.opts.map((opt,oi)=>`
            <input type="radio" class="ro" id="s8_${i}_${oi}" name="s8_${i}" value="${opt}" onchange="s8Record(${i},\`${opt.replace(/`/g,"'")}\`)">
            <label for="s8_${i}_${oi}" class="rl" style="border-radius:8px;padding:10px 14px;text-align:left;border-color:rgba(245,197,24,.3);color:var(--cream);">${opt}</label>
          `).join('')}
        </div></div>`;
    } else if(item.type==='voc'){
      h+=`<div class="skill-row">
        <div class="skill-q">${i+1}. ${item.q}</div>
        <div class="voc-grid">
          ${item.opts.map((opt,oi)=>`
            <div class="voc-card" id="s8vc_${i}_${oi}" onclick="s8Voc(${i},${oi},\`${opt.label}\`)">
              <div class="voc-label">${opt.label}</div>
              <div class="voc-desc">${opt.desc}</div>
            </div>
          `).join('')}
        </div></div>`;
    } else {
      h+=`<div class="skill-row">
        <div class="skill-q">${i+1}. ${item.q}</div>
        <textarea class="item-input" placeholder="Escribe tu respuesta…" style="min-height:70px;resize:vertical;border-radius:8px;" oninput="s8Record(${i},this.value)"></textarea>
      </div>`;
    }
  });
  c.innerHTML=h;
  document.querySelectorAll('#s8_items .ro').forEach(r=>{
    r.addEventListener('change',function(){
      const name=this.name;
      document.querySelectorAll(`[name="${name}"]`).forEach(o=>{
        const lbl=document.querySelector(`label[for="${o.id}"]`);
        if(o.checked){lbl.style.background='rgba(245,197,24,.12)';lbl.style.borderColor='var(--yellow)';lbl.style.color='var(--yellow)';}
        else{lbl.style.background='';lbl.style.borderColor='';lbl.style.color='';}
      });
    });
  });
}

function s8Record(idx,val){
  S8_ANSWERS[idx]=val;
  const done=Object.keys(S8_ANSWERS).filter(k=>S8_ANSWERS[k]?.toString().trim()).length;
  const pct=Math.round(done/S8_ITEMS.length*100);
  document.getElementById('s8_pfill').style.width=pct+'%';
  document.getElementById('s8_pcnt').textContent=`${done} / ${S8_ITEMS.length}`;
}
function s8Voc(qi,oi,label){
  S8_ITEMS[qi].opts.forEach((_,j)=>document.getElementById(`s8vc_${qi}_${j}`)?.classList.remove('selected'));
  document.getElementById(`s8vc_${qi}_${oi}`)?.classList.add('selected');
  s8Record(qi,label);
}

