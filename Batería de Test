function isMobile(){return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);}

function exportPDF(elId,filename){
  isMobile() ? exportMobile(elId,filename) : exportDesktop(elId,filename);
}

function exportDesktop(elId,filename){
  const el=document.getElementById(elId);
  const opt={margin:10,filename:`${filename}_${new Date().toLocaleDateString('es-CL').replace(/\//g,'-')}.pdf`,image:{type:'jpeg',quality:0.97},html2canvas:{scale:2,useCORS:true,backgroundColor:'#ffffff'},jsPDF:{unit:'mm',format:'a4',orientation:'portrait'}};
  const orig=el.style.cssText;
  el.style.cssText='background:white;color:#111;padding:20px;font-family:sans-serif;border:none;border-radius:0;';
  el.querySelectorAll('*').forEach(n=>{if(getComputedStyle(n).color.includes('255, 255, 255'))n.style.color='#111';if(n.classList.contains('bar-track'))n.style.background='#eee';});
  html2pdf().set(opt).from(el).save().then(()=>{el.style.cssText=orig;el.querySelectorAll('*').forEach(n=>{n.style.color='';});el.querySelectorAll('.bar-track').forEach(n=>n.style.background='');});
}

