  {label:'Buena',min:37,max:45,color:'var(--teal)',desc:'Tu autoestima es saludable. Hay aspectos que seguir fortaleciendo, pero tienes una base sólida.'},
  {label:'Regular',min:28,max:36,color:'var(--yellow)',desc:'Tu autoestima es moderada. Hay áreas que podrías trabajar para sentirte más seguro/a de ti mismo/a.'},
