//  PROGRESS
// ══════════════════════════════════════════
function prog(tid, total){
  let done=0;
  if(tid==='s1'){ document.querySelectorAll('#s1_items .item-input').forEach(i=>{if(i.value.trim())done++;}); }
  else if(tid==='s2'){ S2_DIMS.forEach(d=>d.skills.forEach((_,si)=>{if(document.querySelector(`input[name="${d.id}_${si}"]:checked`))done++;})); }
  else if(tid==='s3'){ document.querySelectorAll('#s3_items input[type=checkbox]:checked').forEach(()=>done++); }
  else if(tid==='s4'){ document.querySelectorAll('#s4_items .lk-opt:checked').forEach(()=>done++); }
  else if(tid==='s5'){ document.querySelectorAll('#s5_items .ro:checked').forEach(()=>done++); }
  else if(tid==='s6'){ document.querySelectorAll('#s6_items .ro:checked').forEach(()=>done++); }
  const pct=Math.round(done/total*100);
  document.getElementById(`${tid}_pfill`).style.width=pct+'%';
  document.getElementById(`${tid}_pcnt`).textContent=`${done} / ${total}`;
  document.getElementById(`${tid}_ptxt`).textContent=done===total?'¡Completado!':'Responde todo antes de continuar';
}

