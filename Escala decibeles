<script>
  // ── UTILIDADES ─────────────────────────────────────────────
  function mostrarToast(mensaje) {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.textContent = mensaje;
    document.body.appendChild(toast);
    
    setTimeout(() => {
      toast.classList.add('oculto');
      setTimeout(() => toast.remove(), 300);
    }, 2000);
  }

  function cerrarModal(id) {
    document.getElementById(id).classList.remove('activo');
  }

  // ── MODO OSCURO ────────────────────────────────────────────
  const btnDarkMode = document.getElementById('btnDarkMode');
  const htmlElement = document.documentElement;
  
  // Cargar preferencia guardada
  if (localStorage.getItem('darkMode') === 'true') {
    htmlElement.classList.add('dark-mode');
    btnDarkMode.classList.add('active');
  }

  btnDarkMode.addEventListener('click', () => {
    htmlElement.classList.toggle('dark-mode');
    const isDark = htmlElement.classList.contains('dark-mode');
    localStorage.setItem('darkMode', isDark);
    btnDarkMode.classList.toggle('active');
    mostrarToast(isDark ? '🌙 Modo oscuro activado' : '☀️ Modo claro activado');
  });

  // ── COMPARADOR DE DECIBELES ────────────────────────────────
  const db1Input = document.getElementById('db1');
  const db2Input = document.getElementById('db2');
  const resultadoComparador = document.getElementById('resultado-comparador');

  function calcularComparador() {
    const db1 = parseFloat(db1Input.value) || 0;
    const db2 = parseFloat(db2Input.value) || 0;
    const diferencia = db2 - db1;
    
    let texto = '';
    if (diferencia === 0) {
      texto = `<strong>Mismo nivel:</strong> Ambos valores son iguales (${db1} dB).`;
    } else if (diferencia > 0) {
      const factor = Math.pow(10, diferencia / 10);
      const percepcion = diferencia / 10;
      texto = `<strong>${db2} dB es ${diferencia} dB más alto que ${db1} dB.</strong><br>
               Energía acústica: <strong>×${factor.toFixed(1)}</strong> mayor.<br>
               Percepción: <strong>×${percepcion.toFixed(1)}</strong> más fuerte.`;
    } else {
      const factor = Math.pow(10, -diferencia / 10);
      const percepcion = -diferencia / 10;
      texto = `<strong>${db2} dB es ${-diferencia} dB más bajo que ${db1} dB.</strong><br>
               Energía acústica: <strong>×${factor.toFixed(1)}</strong> menor.<br>
               Percepción: <strong>×${percepcion.toFixed(1)}</strong> más silencioso.`;
    }
    resultadoComparador.innerHTML = texto;
  }

  db1Input.addEventListener('input', calcularComparador);
  db2Input.addEventListener('input', calcularComparador);
  calcularComparador();

  // ── FILTROS DE LEYENDA ─────────────────────────────────────
  const leyendas = document.querySelectorAll('.ley');
  leyendas.forEach(ley => {
    ley.addEventListener('click', () => {
      const filtro = ley.dataset.filtro;
      ley.classList.toggle('activa');
      
      // Mostrar/ocultar filas según filtro
      document.querySelectorAll('.fila').forEach(fila => {
        const zona = fila.dataset.zona;
        const debeVisible = Array.from(leyendas)
          .filter(l => l.classList.contains('activa'))
          .some(l => l.dataset.filtro === zona);
        
        fila.classList.toggle('oculta', !debeVisible);
      });
    });
  });

  // ── MODALES DE FÍSICA ──────────────────────────────────────
  const fisicaCards = document.querySelectorAll('.fisica-card');
  const modalFisica = document.getElementById('modalFisica');
  const modalFisicaTitulo = document.getElementById('modalFisicaTitulo');
  const modalFisicaBody = document.getElementById('modalFisicaBody');

  const fisicaInfo = {
    '+3dB': {
      titulo: 'Regla +3 dB: La energía se duplica',
      contenido: `
        <ul>
          <li><strong>Energía acústica:</strong> Se multiplica por 2</li>
          <li><strong>Percepción humana:</strong> Apenas perceptible (no se siente el doble de fuerte)</li>
          <li><strong>Fórmula:</strong> L₂ = L₁ + 3 dB → I₂ = 2 × I₁</li>
          <li><strong>Ejemplo:</strong> 50 dB → 53 dB duplica la energía, pero tu oído lo percibe muy similar</li>
          <li><strong>Implicación:</strong> Pequeños aumentos en dB representan cambios significativos en energía</li>
        </ul>
      `
    },
    '+10dB': {
      titulo: 'Regla +10 dB: La energía se multiplica por 10',
      contenido: `
        <ul>
          <li><strong>Energía acústica:</strong> Se multiplica por 10</li>
          <li><strong>Percepción humana:</strong> Se percibe como el doble de fuerte</li>
          <li><strong>Fórmula:</strong> L₂ = L₁ + 10 dB → I₂ = 10 × I₁</li>
          <li><strong>Ejemplo real en Iquique:</strong> OMS (55 dB) vs Zona comercial (65 dB) = 10 dB = 10× más energía = 2× más fuerte</li>
          <li><strong>Implicación normativa:</strong> La ley chilena permite 10 veces más energía acústica que la recomendación OMS</li>
        </ul>
      `
    },
    '+20dB': {
      titulo: 'Regla +20 dB: La energía se multiplica por 100',
      contenido: `
        <ul>
          <li><strong>Energía acústica:</strong> Se multiplica por 100</li>
          <li><strong>Percepción humana:</strong> Se percibe como el cuádruple de fuerte</li>
          <li><strong>Fórmula:</strong> L₂ = L₁ + 20 dB → I₂ = 100 × I₁</li>
          <li><strong>Ejemplo:</strong> 55 dB (OMS) vs 75 dB (tráfico intenso) = 20 dB = 100× más energía = 4× más fuerte</li>
          <li><strong>Implicación de salud:</strong> Exposición a 75 dB es 100 veces más energética que el límite recomendado</li>
        </ul>
      `
    }
  };

  fisicaCards.forEach(card => {
    card.addEventListener('click', () => {
      const regla = card.dataset.regla;
      const info = fisicaInfo[regla];
      modalFisicaTitulo.textContent = info.titulo;
      modalFisicaBody.innerHTML = info.contenido;
      modalFisica.classList.add('activo');
    });
  });

  // Cerrar modal al hacer click fuera
  modalFisica.addEventListener('click', (e) => {
    if (e.target === modalFisica) {
      cerrarModal('modalFisica');
    }
  });

  // ── COPIAR TABLA ───────────────────────────────────────────
  const btnCopyTable = document.getElementById('btnCopyTable');
  btnCopyTable.addEventListener('click', () => {
    const tabla = document.getElementById('tablaComparativa');
    let texto = '';
    
    // Encabezados
    tabla.querySelectorAll('thead th').forEach(th => {
      texto += th.textContent.trim() + '\t';
    });
    texto += '\n';
    
    // Filas
    tabla.querySelectorAll('tbody tr').forEach(tr => {
      tr.querySelectorAll('td').forEach(td => {
        texto += td.textContent.trim() + '\t';
      });
      texto += '\n';
    });
    
    navigator.clipboard.writeText(texto).then(() => {
      mostrarToast('✓ Tabla copiada al portapapeles');
    });
  });

  // ── BÚSQUEDA EN FUENTES ────────────────────────────────────
  const buscarFuentes = document.getElementById('buscarFuentes');
  const fuenteItems = document.querySelectorAll('.fuente-item');

  buscarFuentes.addEventListener('input', (e) => {
    const termino = e.target.value.toLowerCase();
    fuenteItems.forEach(item => {
      const texto = item.textContent.toLowerCase();
      item.classList.toggle('oculta', !texto.includes(termino));
    });
  });

  // ── BOTÓN FLOTANTE (VOLVER AL INICIO) ──────────────────────
  const btnFlotante = document.querySelector('.btn-flotante') || (() => {
    const btn = document.createElement('button');
    btn.className = 'btn-flotante';
    btn.innerHTML = '↑';
    btn.title = 'Volver al inicio';
    document.body.appendChild(btn);
    return btn;
  })();

  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      btnFlotante.classList.add('visible');
    } else {
      btnFlotante.classList.remove('visible');
    }
  });

  btnFlotante.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── EXPORTAR A PDF (SIMULADO) ──────────────────────────────
  const btnExportPDF = document.getElementById('btnExportPDF');
  btnExportPDF.addEventListener('click', () => {
    mostrarToast('📥 Función de descarga disponible en navegador');
    window.print();
  });

  // ── ANIMACIÓN DE CARGA ─────────────────────────────────────
  window.addEventListener('load', () => {
    document.body.style.opacity = '1';
  });

  // ── ACCESIBILIDAD: NAVEGACIÓN POR TECLADO ─────────────────
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      cerrarModal('modalFisica');
    }
  });
</script>
</body>
</html>
